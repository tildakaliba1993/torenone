# Copy to .env and fill in. NEVER commit real secrets. All secrets are SERVER-SIDE ONLY.

# --- OpenAI (engineering service only; never exposed to the browser) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5                 # flagship — parsing + narrative (Structured Outputs)
OPENAI_FALLBACK_MODEL=gpt-5.4-mini   # cost fallback if parsing volume grows
# OPENAI_BASE_URL=                   # optional override (Azure/proxy); blank = api.openai.com
# OPENAI_MAX_OUTPUT_TOKENS=2048      # per-request output-token cap (§4.2 cost guard); <=0 disables

# --- Supabase (service-side keys here; browser uses only the anon/public key) ---
SUPABASE_URL=                  # project URL, e.g. https://<ref>.supabase.co (Storage REST upload)
SUPABASE_SERVICE_ROLE_KEY=     # server-side only — bypasses RLS; never ship to client
SUPABASE_JWT_SECRET=           # used by FastAPI to verify user JWTs (HS256)
# SUPABASE_JWT_AUD=authenticated   # expected JWT audience; set empty to disable aud check
# SUPABASE_DB_URL=             # direct Postgres connection for the report store (runs/reports rows).
                               # When SUPABASE_URL + SERVICE_ROLE_KEY + DB_URL are all set, /design
                               # persists to Supabase; otherwise it uses the in-memory store.

# --- Observability (optional; all no-op unless set) ---
# SENTRY_DSN=                    # service-side error tracking; blank = disabled (local/dev/CI)
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0

# --- Frontend (safe to expose; prefixed for Next.js public env) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENGINEERING_SERVICE_URL=http://localhost:8000
# NEXT_PUBLIC_SENTRY_DSN=        # web error tracking (§5.1); blank = disabled
# CSP_ENFORCE=true               # enforce the Content-Security-Policy (§7.4); default = report-only
