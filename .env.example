# Copy to .env and fill in. NEVER commit real secrets. All secrets are SERVER-SIDE ONLY.

# --- Anthropic (engineering service only; never exposed to the browser) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Supabase (service-side keys here; browser uses only the anon/public key) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=     # server-side only — bypasses RLS; never ship to client
SUPABASE_JWT_SECRET=           # used by FastAPI to verify user JWTs

# --- Frontend (safe to expose; prefixed for Next.js public env) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENGINEERING_SERVICE_URL=http://localhost:8000
