<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TorenOne — Structural Calculation Report</title>
  <style>
    /* ------------------------------------------------------------------ */
    /* Design tokens — steel-blue brand                                    */
    /* ------------------------------------------------------------------ */
    :root {
      --color-brand:       #1B3A57;
      --color-brand-light: #2D5F8A;
      --color-pass:        #166534;
      --color-pass-bg:     #DCFCE7;
      --color-fail:        #991B1B;
      --color-fail-bg:     #FEE2E2;
      --color-warn:        #92400E;
      --color-warn-bg:     #FEF3C7;
      --color-border:      #D1D5DB;
      --color-text:        #111827;
      --color-muted:       #6B7280;
      --font-mono:         "Courier New", Courier, monospace;
      --font-sans:         Arial, Helvetica, sans-serif;
    }

    /* ------------------------------------------------------------------ */
    /* Base                                                                */
    /* ------------------------------------------------------------------ */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-sans);
      font-size: 10pt;
      color: var(--color-text);
      background: #fff;
      padding: 20mm 18mm;
    }

    /* ------------------------------------------------------------------ */
    /* Cover / header                                                      */
    /* ------------------------------------------------------------------ */
    .cover {
      background: var(--color-brand);
      color: #fff;
      padding: 18pt 20pt;
      margin-bottom: 16pt;
      border-radius: 3pt;
    }
    .cover h1 { font-size: 18pt; font-weight: bold; margin-bottom: 4pt; }
    .cover .subtitle { font-size: 10pt; opacity: 0.85; }
    .cover .meta { font-size: 9pt; margin-top: 8pt; opacity: 0.75; font-family: var(--font-mono); }

    /* ------------------------------------------------------------------ */
    /* Section headings                                                    */
    /* ------------------------------------------------------------------ */
    h2 {
      font-size: 12pt;
      font-weight: bold;
      color: var(--color-brand);
      border-bottom: 1.5pt solid var(--color-brand);
      padding-bottom: 3pt;
      margin: 16pt 0 8pt;
    }
    h3 {
      font-size: 10pt;
      font-weight: bold;
      color: var(--color-brand-light);
      margin: 10pt 0 4pt;
    }

    /* ------------------------------------------------------------------ */
    /* Tables                                                              */
    /* ------------------------------------------------------------------ */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10pt;
      font-size: 9.5pt;
    }
    th {
      background: var(--color-brand);
      color: #fff;
      text-align: left;
      padding: 4pt 6pt;
      font-weight: bold;
    }
    td {
      padding: 3pt 6pt;
      border-bottom: 0.5pt solid var(--color-border);
    }
    tr:nth-child(even) td { background: #F9FAFB; }

    /* Monospaced numeric columns */
    .num { font-family: var(--font-mono); text-align: right; }

    /* ------------------------------------------------------------------ */
    /* Pass / fail badges  (PRD FR-19: icon + label + colour, never alone) */
    /* ------------------------------------------------------------------ */
    .badge {
      display: inline-block;
      padding: 1pt 5pt;
      border-radius: 2pt;
      font-weight: bold;
      font-size: 8.5pt;
      font-family: var(--font-mono);
    }
    .badge-pass { background: var(--color-pass-bg); color: var(--color-pass); }
    .badge-near { background: var(--color-warn-bg); color: var(--color-warn); }
    .badge-fail { background: var(--color-fail-bg); color: var(--color-fail); }

    /* ------------------------------------------------------------------ */
    /* Utilisation bar                                                     */
    /* ------------------------------------------------------------------ */
    .util-bar-wrap { width: 60pt; height: 7pt; background: #E5E7EB; display: inline-block;
                     border-radius: 1pt; vertical-align: middle; }
    .util-bar      { height: 100%; border-radius: 1pt; }
    .util-low      { background: var(--color-pass); }
    .util-mid      { background: #D97706; }
    .util-high     { background: var(--color-fail); }

    /* ------------------------------------------------------------------ */
    /* Info / warning boxes                                                */
    /* ------------------------------------------------------------------ */
    .box {
      border-left: 3pt solid var(--color-brand);
      background: #F0F4F8;
      padding: 7pt 10pt;
      margin: 8pt 0;
      font-size: 9pt;
    }
    .box-warn {
      border-left-color: #D97706;
      background: var(--color-warn-bg);
      color: var(--color-warn);
    }
    .box-prov {
      border-left-color: #D97706;
      background: var(--color-warn-bg);
    }

    /* ------------------------------------------------------------------ */
    /* Provenance label                                                    */
    /* ------------------------------------------------------------------ */
    .provenance {
      font-size: 8pt;
      color: var(--color-muted);
      font-style: italic;
      margin-top: 12pt;
      border-top: 0.5pt solid var(--color-border);
      padding-top: 6pt;
    }

    /* ------------------------------------------------------------------ */
    /* Page break hints (WeasyPrint honours these)                        */
    /* ------------------------------------------------------------------ */
    .page-break { page-break-before: always; }
  </style>
</head>
<body>

{# ================================================================== #}
{# Macro: status_badge(utilisation, passed)                           #}
{# Three-tier status per PRD FR-19: icon + label + colour, never      #}
{# colour alone.                                                       #}
{#   PASS       util < near_limit_threshold (green  ✓)                #}
{#   NEAR LIMIT threshold ≤ util ≤ 1.0      (amber  ⚠)               #}
{#   FAIL       util > 1.0 OR not passed    (red    ✗)                #}
{# ================================================================== #}
{% macro status_badge(utilisation, passed) -%}
  {%- if not passed or utilisation > 1.0 -%}
    <span class="badge badge-fail">&#10007; FAIL</span>
  {%- elif utilisation >= near_limit_threshold -%}
    <span class="badge badge-near">&#9888; NEAR LIMIT</span>
  {%- else -%}
    <span class="badge badge-pass">&#10003; PASS</span>
  {%- endif -%}
{%- endmacro %}

{# Macro: checks_table(checks) — a clause-referenced utilisation + status table #}
{% macro checks_table(checks) -%}
<table>
  <tr>
    <th style="width:34%">Check</th>
    <th style="width:30%">Clause</th>
    <th style="width:14%" class="num">Utilisation</th>
    <th style="width:22%">Status</th>
  </tr>
  {% for c in checks %}
  <tr>
    <td>{{ c.name }}</td>
    <td style="font-family: var(--font-mono); font-size:8pt;">{{ c.clause }}</td>
    <td class="num">{{ "%.4f"|format(c.utilisation) }}</td>
    <td>
      {{ status_badge(c.utilisation, c.passed) }}
      {% if c.detail %}<br><span style="font-size:7.5pt; color:var(--color-muted);">{{ c.detail }}</span>{% endif %}
    </td>
  </tr>
  {% endfor %}
</table>
{%- endmacro %}

<!-- ================================================================ -->
<!-- COVER                                                             -->
<!-- ================================================================ -->
<div class="cover">
  <h1>Structural Calculation Report</h1>
  <div class="subtitle">Single-span portal frame — SANS 10162-1:2011 / SANS 10160 series</div>
  <div class="meta">
    Generated: {{ generated_at }} (UTC)<br>
    Frame: {{ geom.span_m }} m span &times; {{ geom.eaves_height_m }} m eaves &times; {{ geom.roof_pitch_deg }}&deg; pitch &times; {{ geom.bay_spacing_m }} m bay<br>
    Report fingerprint: <span style="font-family: monospace; font-size:8pt;">{{ report_fingerprint[:16] }}&hellip;</span>
  </div>
</div>

<!-- ================================================================ -->
<!-- PROVENANCE STATEMENT (PRD FR-26)                                  -->
<!-- ================================================================ -->
<div class="box">
  <strong>Provenance:</strong> All engineering values in this report are computed by the
  <strong>TorenOne deterministic kernel</strong> — not by an AI language model. Numbers are
  traceable to verified SANS clauses cited alongside each check. No arithmetic is performed by AI.
</div>

{% if provisional_warnings %}
<div class="box box-prov">
  <strong>&#9888; PROVISIONAL values — engineer sign-off required before use in construction:</strong>
  <ul style="margin-top:4pt; padding-left:14pt;">
    {% for w in provisional_warnings %}
    <li>{{ w }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<!-- ================================================================ -->
<!-- 1. ASSUMPTIONS AND LIMITATIONS (Design §B.7)                     -->
<!-- ================================================================ -->
<h2>1. Assumptions and Limitations</h2>
<div class="box">
  <strong>Assumed:</strong>
  <ul style="margin-top:4pt; padding-left:14pt;">
    <li>Single-span symmetric portal frame with pinned column bases.</li>
    <li>Elastic first-order plane-frame analysis (PyNiteFEA 1.6.2); sway amplified by U2 factor (SANS 10162-1 cl. 8.7).</li>
    <li>Steel grade S355JR: fy = {{ fy_mpa }} MPa (t &le; 16 mm); E = 200 000 MPa; G = 77 000 MPa (SANS 10162-1 cl. 3.2).</li>
    <li>Section library: 64 SAISC sections (IPE-AA/IPE 100–200, UBs, UCs); lightest-first auto-sizing.</li>
    <li>Vertical deflection limit: L/240 (SANS 10162-1 Annex D, informative).</li>
    <li>Lateral sway limit: H/400 (SANS 10162-1 Annex D, informative).</li>
    <li>Load combination factors from SANS 10160-1 (DRAFT — PROVISIONAL).</li>
    <li>Indicative cost rate: R{{ cost_rate_zar_per_kg }}/kg (PROVISIONAL — confirm with fabricator).</li>
  </ul>
</div>
<div class="box box-warn">
  <strong>Out of scope / engineer must verify:</strong>
  <ul style="margin-top:4pt; padding-left:14pt;">
    <li>Connection design (eaves knee, apex, column base plate).</li>
    <li>Foundation design and ground conditions.</li>
    <li>Purlins, girts, and secondary steelwork.</li>
    <li>Seismic loading (SANS 10160-4).</li>
    <li>Fatigue and dynamic effects.</li>
    <li>Fire resistance and special exposure classes.</li>
    <li>All PROVISIONAL values (fy, load factors, SAISC section data) must be confirmed by a registered engineer before use in construction documents.</li>
  </ul>
</div>

<!-- ================================================================ -->
<!-- 2. FRAME GEOMETRY AND INPUT PARAMETERS                           -->
<!-- ================================================================ -->
<h2>2. Frame Geometry and Input Parameters</h2>
<table>
  <tr><th style="width:50%">Parameter</th><th>Value</th></tr>
  <tr><td>Span</td>              <td class="num">{{ geom.span_m }} m</td></tr>
  <tr><td>Eaves height</td>      <td class="num">{{ geom.eaves_height_m }} m</td></tr>
  <tr><td>Roof pitch</td>        <td class="num">{{ geom.roof_pitch_deg }}&deg;</td></tr>
  <tr><td>Bay spacing</td>       <td class="num">{{ geom.bay_spacing_m }} m</td></tr>
  <tr><td>Number of bays</td>    <td class="num">{{ geom.number_of_bays }}</td></tr>
  <tr><td>Apex height</td>       <td class="num">{{ "%.3f"|format(geom.apex_height_m) }} m</td></tr>
  <tr><td>Base fixity</td>       <td>{{ base_fixity }}</td></tr>
  <tr><td>Steel grade</td>       <td>{{ steel_grade }}</td></tr>
  <tr><td>Dead load (roof)</td>  <td class="num">{{ dead.roof_kpa }} kPa</td></tr>
  <tr><td>Dead load (services)</td><td class="num">{{ dead.services_kpa }} kPa</td></tr>
  <tr><td>Basic wind speed</td>  <td class="num">{{ wind.basic_wind_speed_ms }} m/s</td></tr>
  <tr><td>Terrain category</td>  <td>{{ wind.terrain_category.value }}</td></tr>
</table>

<!-- ================================================================ -->
<!-- 3. DIAGRAMS (Task 2.3)                                           -->
<!-- ================================================================ -->
<h2>3. Frame Diagrams</h2>

<h3>Frame Geometry</h3>
<div style="text-align:center; margin-bottom:10pt;">
  <img src="data:image/png;base64,{{ geom_png_b64 }}"
       alt="Portal frame geometry diagram"
       style="max-width:100%; height:auto; border:0.5pt solid var(--color-border);">
</div>

<h3>Bending Moment Diagram + Shear Force Diagram — Governing ULS-1 Combination</h3>
<p style="font-size:8.5pt; color:var(--color-muted); margin-bottom:4pt;">
  Forces computed by first-order elastic plane-frame analysis (PyNiteFEA).
  Moments plotted perpendicular to member axis; positive offset = sagging convention.
  Values in kN·m (BMD) and kN (SFD).
</p>
<div style="text-align:center; margin-bottom:10pt;">
  <img src="data:image/png;base64,{{ bmd_sfd_b64 }}"
       alt="Bending moment diagram and shear force diagram"
       style="max-width:100%; height:auto; border:0.5pt solid var(--color-border);">
</div>

<!-- ================================================================ -->
<!-- 4. DESIGN RESULTS SUMMARY                                        -->
<!-- ================================================================ -->
<h2>4. Design Results Summary</h2>

<table>
  <tr><th>Member</th><th>Section</th><th class="num">Governing util.</th><th>Status</th></tr>
  {% for s in sections %}
  <tr>
    <td>{{ s.member | capitalize }}</td>
    <td style="font-family: var(--font-mono)">{{ s.designation }}</td>
    <td class="num">{{ "%.3f"|format(member_util[s.member]) }}</td>
    <td>{{ status_badge(member_util[s.member], member_pass[s.member]) }}</td>
  </tr>
  {% endfor %}
</table>

<table>
  <tr>
    <th style="width:50%">Overall result</th>
    <td>
      {% if result_passed %}
      <span class="badge badge-pass" style="font-size:11pt;">&#10003; ALL CHECKS PASS</span>
      {% else %}
      <span class="badge badge-fail" style="font-size:11pt;">&#10007; ONE OR MORE CHECKS FAIL</span>
      {% endif %}
    </td>
  </tr>
  <tr>
    <td>Governing utilisation</td>
    <td class="num">{{ "%.4f"|format(governing_utilisation) }}</td>
  </tr>
</table>

<!-- ================================================================ -->
<!-- 4. CODE CHECKS (SANS 10162-1:2011)                               -->
<!-- ================================================================ -->
<h2>5. Member Code Checks — SANS 10162-1:2011</h2>
<p style="font-size:8.5pt; color:var(--color-muted); margin-bottom:6pt;">
  Utilisation = demand / capacity. Values &le; 1.00 indicate compliance.
  All clauses refer to SANS 10162-1:2011 unless otherwise stated.
  Connection, baseplate and footing checks are in sections 6&ndash;8.
</p>
{{ checks_table(member_checks) }}

<!-- ================================================================ -->
<!-- 6. CONNECTION DESIGN — eaves + apex (PRD FR-28)                   -->
<!-- ================================================================ -->
<h2>6. Connection Design (eaves &amp; apex)</h2>
{% if connections %}
<div class="box box-prov" style="font-size:8.5pt; margin-bottom:8pt;">
  Bolted end-plate moment connections by the flange-force-couple method. ⚠️
  <strong>PROVISIONAL</strong> — SANS 10162-1 connection coefficients pending registered-engineer
  sign-off (see assumptions). Scope-limited to the single-bay portal-frame eaves &amp; apex joints.
</div>
{% for conn in connections %}
<h3>6.{{ loop.index }} {{ conn.location | capitalize }} connection</h3>
<p style="font-size:8.5pt; margin:2pt 0 4pt;">
  <strong>{{ conn.description }}</strong><br>
  <span style="color:var(--color-muted);">Design forces:
    M = {{ "%.1f"|format(conn.design_moment_knm) }} kN&middot;m,
    V = {{ "%.1f"|format(conn.design_shear_kn) }} kN,
    N = {{ "%.1f"|format(conn.design_axial_kn) }} kN ·
    governing utilisation {{ "%.2f"|format(conn.max_utilisation) }}
    {{ status_badge(conn.max_utilisation, conn.passed) }}</span>
</p>
{{ checks_table(conn.checks) }}
{% endfor %}
{% else %}
<p style="font-size:8.5pt; color:var(--color-muted);">No connection design in this result.</p>
{% endif %}

<!-- ================================================================ -->
<!-- 7. COLUMN BASEPLATE (PRD FR-29)                                   -->
<!-- ================================================================ -->
<h2>7. Column Baseplate{% if baseplate %} ({{ baseplate.base_fixity }}){% endif %}</h2>
{% if baseplate %}
<div class="box box-prov" style="font-size:8.5pt; margin-bottom:8pt;">
  ⚠️ <strong>PROVISIONAL</strong> — SANS 10162-1 / concrete-bearing coefficients pending
  engineer sign-off.
</div>
<p style="font-size:8.5pt; margin:2pt 0 4pt;">
  <strong>{{ baseplate.description }}</strong><br>
  <span style="color:var(--color-muted);">Base reactions:
    N = {{ "%.1f"|format(baseplate.design_axial_kn) }} kN,
    V = {{ "%.1f"|format(baseplate.design_shear_kn) }} kN,
    M = {{ "%.1f"|format(baseplate.design_moment_knm) }} kN&middot;m ·
    governing utilisation {{ "%.2f"|format(baseplate.max_utilisation) }}
    {{ status_badge(baseplate.max_utilisation, baseplate.passed) }}</span>
</p>
{{ checks_table(baseplate.checks) }}
{% else %}
<p style="font-size:8.5pt; color:var(--color-muted);">No baseplate design in this result.</p>
{% endif %}

<!-- ================================================================ -->
<!-- 8. PAD FOOTING (SANS 10100-1, PRD FR-30)                          -->
<!-- ================================================================ -->
<h2>8. Pad Footing</h2>
{% if footing %}
<p style="font-size:8.5pt; margin:2pt 0 4pt;">
  Reinforced-concrete pad to <strong>SANS 10100-1</strong>.<br>
  <strong>{{ footing.description }}</strong><br>
  <span style="color:var(--color-muted);">
    Service axial {{ "%.1f"|format(footing.design_service_axial_kn) }} kN ·
    factored {{ "%.1f"|format(footing.design_factored_axial_kn) }} kN ·
    allowable bearing {{ "%.0f"|format(footing.allowable_bearing_kpa) }} kPa ·
    governing utilisation {{ "%.2f"|format(footing.max_utilisation) }}
    {{ status_badge(footing.max_utilisation, footing.passed) }}</span>
</p>
{{ checks_table(footing.checks) }}
{% else %}
<div class="box box-prov" style="font-size:8.5pt;">
  <strong>Pad footing not designed.</strong> No allowable bearing pressure was supplied
  (a site/geotechnical input — never assumed). Provide it to complete the foundation design.
</div>
{% endif %}

<!-- ================================================================ -->
<!-- 9. STEEL SCHEDULE + TONNAGE + COST                               -->
<!-- ================================================================ -->
<h2>9. Steel Schedule, Tonnage &amp; Cost</h2>
<table>
  <tr>
    <th>Member</th>
    <th>Section</th>
    <th class="num">Mass/m (kg/m)</th>
    <th class="num">Length (m)</th>
    <th class="num">Mass (kg)</th>
  </tr>
  {% for row in schedule %}
  <tr>
    <td>{{ row.member | capitalize }}</td>
    <td style="font-family: var(--font-mono)">{{ row.designation }}</td>
    <td class="num">{{ "%.1f"|format(row.mass_per_m) }}</td>
    <td class="num">{{ "%.2f"|format(row.length_m) }}</td>
    <td class="num">{{ "%.1f"|format(row.mass_kg) }}</td>
  </tr>
  {% endfor %}
  <tr style="font-weight:bold; background:#EFF6FF;">
    <td colspan="4" style="text-align:right; padding-right:6pt;">Total per frame</td>
    <td class="num">{{ "%.1f"|format(total_mass_kg) }} kg</td>
  </tr>
  {% if total_steel_tonnes is not none %}
  <tr style="font-weight:bold; background:#EFF6FF;">
    <td colspan="4" style="text-align:right; padding-right:6pt;">Total steel tonnage</td>
    <td class="num">{{ "%.3f"|format(total_steel_tonnes) }} t</td>
  </tr>
  {% endif %}
</table>

<table>
  <tr>
    <th style="width:60%">Indicative fabricated steel cost (PROVISIONAL — R{{ cost_rate_zar_per_kg }}/kg)</th>
    <td class="num" style="font-weight:bold; font-size:11pt;">
      R {{ "{:,.0f}".format(indicative_cost_zar) }} ZAR
    </td>
  </tr>
</table>

<div class="box box-prov" style="font-size:8.5pt;">
  Cost rate R{{ cost_rate_zar_per_kg }}/kg is PROVISIONAL. Market range: R18 000–R25 000/tonne (2025).
  Confirm with local fabricator before using in project cost estimates.
</div>

<!-- ================================================================ -->
<!-- 6. STANDARDS AND RULES VERSION (PRD FR-20)                       -->
<!-- ================================================================ -->
<h2>10. Standards and Rules Version</h2>
<table>
  <tr><th style="width:40%">Standard</th><th>Version / edition used</th></tr>
  {% for key, val in rules_version.items() %}
  <tr>
    <td>{{ key }}</td>
    <td style="font-family: var(--font-mono)">{{ val }}</td>
  </tr>
  {% endfor %}
</table>

<!-- ================================================================ -->
<!-- 8. SHOW YOUR WORKING — Line-by-line audit (PRD FR-26)            -->
<!-- ================================================================ -->
<h2>11. Show Your Working — Line-by-Line Audit</h2>
<div class="box" style="font-size:8.5pt; margin-bottom:8pt;">
  <strong>FR-26 provenance:</strong> Every number in this section is
  <strong>computed by the TorenOne deterministic kernel</strong> — not by an AI language model.
  Values are traceable to the SANS clauses cited. No arithmetic is performed by AI.
</div>

<!-- 11.1 Characteristic Loads -->
<h3>11.1 Characteristic Loads (Dead + Imposed)</h3>
<table>
  <tr><th style="width:35%">Load component</th><th>Working</th><th class="num">Value</th><th class="num">Unit</th></tr>

  <tr><th colspan="4" style="background:var(--color-brand-light); font-size:8.5pt;">
    Dead Loads — Permanent (G)
  </th></tr>
  <tr>
    <td>Roof area load (dead)</td>
    <td>{{ dead.roof_kpa }} + {{ dead.services_kpa }} kPa</td>
    <td class="num">{{ "%.3f"|format(dead_rafter_area_load_kpa) }}</td>
    <td>kPa</td>
  </tr>
  <tr>
    <td>Rafter area UDL</td>
    <td>{{ "%.3f"|format(dead_rafter_area_load_kpa) }} kPa &times; {{ "%.1f"|format(dead_trib_width_m) }} m</td>
    <td class="num">{{ "%.3f"|format(dead_rafter_area_load_kpa * dead_trib_width_m) }}</td>
    <td>kN/m</td>
  </tr>
  <tr>
    <td>Rafter self-weight</td>
    <td>Section mass/m &times; g</td>
    <td class="num">{{ "%.3f"|format(dead_rafter_sw_kn_m) }}</td>
    <td>kN/m</td>
  </tr>
  <tr style="font-weight:bold; background:#EFF6FF;">
    <td>Total rafter dead UDL</td>
    <td>area UDL + self-weight</td>
    <td class="num">{{ "%.3f"|format(dead_rafter_udl_kn_m) }}</td>
    <td>kN/m</td>
  </tr>
  <tr>
    <td>Column self-weight</td>
    <td>Section mass/m &times; g</td>
    <td class="num">{{ "%.3f"|format(dead_col_sw_kn_m) }}</td>
    <td>kN/m</td>
  </tr>

  <tr><th colspan="4" style="background:var(--color-brand-light); font-size:8.5pt;">
    Imposed Loads — Variable (Q) &mdash; {{ imposed_category }}
  </th></tr>
  <tr>
    <td>Characteristic area load</td>
    <td>{{ imposed_clause }}</td>
    <td class="num">{{ "%.1f"|format(imposed_area_kpa) }}</td>
    <td>kPa</td>
  </tr>
  <tr>
    <td>Tributary width</td>
    <td>Bay spacing</td>
    <td class="num">{{ "%.1f"|format(dead_trib_width_m) }}</td>
    <td>m</td>
  </tr>
  <tr style="font-weight:bold; background:#EFF6FF;">
    <td>Total imposed UDL</td>
    <td>{{ "%.1f"|format(imposed_area_kpa) }} kPa &times; {{ "%.1f"|format(dead_trib_width_m) }} m</td>
    <td class="num">{{ "%.3f"|format(imposed_udl_kn_m) }}</td>
    <td>kN/m</td>
  </tr>
</table>

{% if wind_actions %}
<!-- 11.2 Characteristic Wind Actions -->
<h3>11.2 Characteristic Wind Actions — SANS 10160-3:2019</h3>
<p style="font-size:8.5pt; color:var(--color-muted); margin-bottom:4pt;">
  Transverse wind (&theta; = 0&deg;), {{ wind_actions.scenario }}. Reference height
  z<sub>e</sub> = {{ "%.2f"|format(wind_actions.reference_height_m) }} m.
</p>
<table>
  <tr><th style="width:40%">Quantity</th><th class="num">Value</th><th>Source</th></tr>
  <tr>
    <td>Peak velocity pressure q<sub>p</sub></td>
    <td class="num">{{ "%.3f"|format(wind_actions.peak_velocity_pressure_kpa) }} kPa</td>
    <td style="font-size:8pt;">SANS 10160-3 cl. 7</td>
  </tr>
</table>
<p style="font-size:8.5pt; margin:6pt 0 2pt;">
  Net pressure coefficients (c<sub>pe</sub> &minus; c<sub>pi</sub>) and member line loads
  (n = q<sub>p</sub>&middot;(c<sub>pe</sub>&minus;c<sub>pi</sub>)&middot;bay) per load case:
</p>
<table>
  <tr>
    <th>Wind load case</th>
    <th class="num">Wall&nbsp;W</th><th class="num">Wall&nbsp;L</th>
    <th class="num">Roof&nbsp;W</th><th class="num">Roof&nbsp;L</th>
    <th class="num">Col&nbsp;W</th><th class="num">Col&nbsp;L</th>
    <th class="num">Raf&nbsp;W</th><th class="num">Raf&nbsp;L</th>
  </tr>
  {% for c in wind_actions.cases %}
  <tr>
    <td style="font-size:8pt;">{{ c.name }}</td>
    <td class="num">{{ "%.2f"|format(c.net_cp_windward_wall) }}</td>
    <td class="num">{{ "%.2f"|format(c.net_cp_leeward_wall) }}</td>
    <td class="num">{{ "%.2f"|format(c.net_cp_windward_roof) }}</td>
    <td class="num">{{ "%.2f"|format(c.net_cp_leeward_roof) }}</td>
    <td class="num">{{ "%.2f"|format(c.windward_column_udl_kn_per_m) }}</td>
    <td class="num">{{ "%.2f"|format(c.leeward_column_udl_kn_per_m) }}</td>
    <td class="num">{{ "%.2f"|format(c.windward_rafter_udl_kn_per_m) }}</td>
    <td class="num">{{ "%.2f"|format(c.leeward_rafter_udl_kn_per_m) }}</td>
  </tr>
  {% endfor %}
</table>
<p style="font-size:8pt; color:var(--color-muted); margin-top:3pt;">
  {{ wind_actions.clause }}. Coefficients are c<sub>pe</sub>&minus;c<sub>pi</sub>; line loads in
  kN/m. Columns: horizontal, +ve = inward pressure. Rafters: normal to roof, &minus;ve = uplift.
  <strong>These wind actions are tabulated for transparency; the wind load-combination frame
  analysis (ULS-2/3, SLS-2) is not yet run &mdash; see &sect;1 Assumptions &amp; Limitations.</strong>
</p>
{% endif %}

<!-- 11.3 Factored ULS-1 Loads -->
<h3>11.3 Factored Loads — {{ uls1_name }} ({{ combo_clause }})</h3>
<table>
  <tr><th style="width:30%">Component</th><th>Characteristic (kN/m)</th>
      <th>&gamma; factor</th><th class="num">Factored (kN/m)</th></tr>
  <tr>
    <td>Rafter dead</td>
    <td class="num">{{ "%.3f"|format(dead_rafter_udl_kn_m) }}</td>
    <td class="num">&gamma;<sub>G</sub> = {{ gamma_G }}</td>
    <td class="num">{{ "%.3f"|format(gamma_G * dead_rafter_udl_kn_m) }}</td>
  </tr>
  <tr>
    <td>Rafter imposed</td>
    <td class="num">{{ "%.3f"|format(imposed_udl_kn_m) }}</td>
    <td class="num">&gamma;<sub>Q</sub> = {{ gamma_Q }}</td>
    <td class="num">{{ "%.3f"|format(gamma_Q * imposed_udl_kn_m) }}</td>
  </tr>
  <tr style="font-weight:bold; background:#EFF6FF;">
    <td>Total rafter factored UDL</td>
    <td colspan="2">&gamma;<sub>G</sub>&middot;G + &gamma;<sub>Q</sub>&middot;Q</td>
    <td class="num">{{ "%.3f"|format(uls_rafter_udl_kn_m) }}</td>
  </tr>
  <tr>
    <td>Column axial UDL</td>
    <td class="num">{{ "%.3f"|format(dead_col_sw_kn_m + dead_wall_kn_m) }}</td>
    <td class="num">&gamma;<sub>G</sub> = {{ gamma_G }}</td>
    <td class="num">{{ "%.3f"|format(uls_col_udl_kn_m) }}</td>
  </tr>
</table>

<!-- 11.4 Governing Analysis Forces -->
<h3>11.4 Governing Analysis Forces — {{ uls1_name }}</h3>
<p style="font-size:8.5pt; color:var(--color-muted); margin-bottom:4pt;">
  First-order elastic plane-frame analysis (PyNiteFEA). Forces at key structural locations.
</p>
<table>
  <tr><th>Location</th><th class="num">M (kN&middot;m)</th>
      <th class="num">V (kN)</th><th class="num">N (kN)</th></tr>
  <tr>
    <td>Eaves / knee joint (EL)</td>
    <td class="num">{{ "%.2f"|format(eaves_moment_knm) }}</td>
    <td class="num">{{ "%.2f"|format(eaves_shear_kn) }}</td>
    <td class="num">{{ "%.2f"|format(eaves_axial_kn) }}</td>
  </tr>
  <tr>
    <td>Apex (AP)</td>
    <td class="num">{{ "%.2f"|format(apex_moment_knm) }}</td>
    <td class="num">{{ "%.2f"|format(apex_shear_kn) }}</td>
    <td class="num">{{ "%.2f"|format(apex_axial_kn) }}</td>
  </tr>
  <tr>
    <td>Column base (BL) — pinned</td>
    <td class="num">0.00</td>
    <td class="num">{{ "%.2f"|format(base_shear_kn) }}</td>
    <td class="num">{{ "%.2f"|format(base_axial_kn) }}</td>
  </tr>
</table>

<!-- 11.4 Member Capacity Working -->
{% for mw in member_workings %}
<h3>11.{{ loop.index + 4 }} {{ mw.member | capitalize }} Capacity — {{ mw.designation }}</h3>

<h4 style="font-size:9pt; color:var(--color-brand-light); margin: 6pt 0 3pt;">Section Properties</h4>
<table>
  <tr>
    <th style="width:40%">Property</th><th class="num">Value</th><th>Unit</th>
  </tr>
  <tr><td>Area A</td>
      <td class="num">{{ "{:,.0f}".format(mw.area_mm2) }}</td><td>mm&sup2;</td></tr>
  <tr><td>Second moment I<sub>x</sub> (major)</td>
      <td class="num">{{ "{:,.0f}".format(mw.ix_mm4) }}</td><td>mm&sup4;</td></tr>
  <tr><td>Second moment I<sub>y</sub> (minor)</td>
      <td class="num">{{ "{:,.0f}".format(mw.iy_mm4) }}</td><td>mm&sup4;</td></tr>
  <tr><td>Plastic modulus Z<sub>pl</sub></td>
      <td class="num">{{ "{:,.0f}".format(mw.zpl_mm3) }}</td><td>mm&sup3;</td></tr>
  <tr><td>Minor-axis radius of gyration r<sub>y</sub></td>
      <td class="num">{{ "%.1f"|format(mw.ry_mm) }}</td><td>mm</td></tr>
  <tr><td>Section class (SANS 10162-1 cl. 11.2)</td>
      <td class="num">{{ mw.section_class }}</td><td>—</td></tr>
  <tr><td>Design yield stress f<sub>y</sub></td>
      <td class="num">{{ "%.0f"|format(mw.fy_mpa) }}</td><td>MPa</td></tr>
</table>

<h4 style="font-size:9pt; color:var(--color-brand-light); margin: 6pt 0 3pt;">Capacity Checks</h4>
<table>
  <tr>
    <th style="width:22%">Check</th>
    <th style="width:28%">Key inputs</th>
    <th class="num" style="width:20%">Capacity</th>
    <th style="width:10%">Clause</th>
  </tr>
  <tr>
    <td>Slenderness KL/r</td>
    <td>KL = {{ "%.0f"|format(mw.KL_mm) }} mm, r<sub>y</sub> = {{ "%.1f"|format(mw.ry_mm) }} mm</td>
    <td class="num">{{ "%.1f"|format(mw.kl_over_r) }} &le; 200</td>
    <td style="font-family: var(--font-mono); font-size:7.5pt;">cl. 10.4.2.1</td>
  </tr>
  <tr>
    <td>Axial C<sub>r</sub></td>
    <td>&phi; = 0.90, A = {{ "{:,.0f}".format(mw.area_mm2) }} mm&sup2;, f<sub>y</sub> = {{ "%.0f"|format(mw.fy_mpa) }} MPa</td>
    <td class="num">{{ "%.2f"|format(mw.cr_kn) }} kN</td>
    <td style="font-family: var(--font-mono); font-size:7.5pt;">cl. 13.3.1</td>
  </tr>
  <tr>
    <td>Shear V<sub>r</sub></td>
    <td>h<sub>w</sub> = {{ "%.1f"|format(mw.hw_mm) }} mm, &phi; = 0.90, f<sub>y</sub> = {{ "%.0f"|format(mw.fy_mpa) }} MPa</td>
    <td class="num">{{ "%.2f"|format(mw.vr_kn) }} kN</td>
    <td style="font-family: var(--font-mono); font-size:7.5pt;">cl. 13.4.1.1</td>
  </tr>
  <tr>
    <td>Elastic M<sub>cr</sub></td>
    <td>L<sub>u</sub> = {{ "%.0f"|format(mw.LTB_mm) }} mm, &omega;<sub>2</sub> = 1.00</td>
    <td class="num">{{ "%.2f"|format(mw.mcr_knm) }} kN&middot;m</td>
    <td style="font-family: var(--font-mono); font-size:7.5pt;">cl. 13.6</td>
  </tr>
  <tr style="font-weight:bold; background:#EFF6FF;">
    <td>Moment M<sub>r</sub> (LTB)</td>
    <td>Class {{ mw.section_class }}, Z<sub>pl</sub> = {{ "{:,.0f}".format(mw.zpl_mm3) }} mm&sup3;</td>
    <td class="num">{{ "%.2f"|format(mw.mr_knm) }} kN&middot;m</td>
    <td style="font-family: var(--font-mono); font-size:7.5pt;">cl. 13.5/13.6</td>
  </tr>
</table>
{% endfor %}

<!-- ================================================================ -->
<!-- 9. AUDIT METADATA (PRD FR-20)                                    -->
<!-- ================================================================ -->
<h2>12. Audit Metadata</h2>
<p style="font-size:8.5pt; color:var(--color-muted); margin-bottom:6pt;">
  FR-20: Reports record the code-rule version, complete input spec, and a timestamp
  so that results can be reproduced exactly from the same inputs.
</p>

<h3>Report Identity</h3>
<table>
  <tr><th style="width:40%">Field</th><th>Value</th></tr>
  <tr>
    <td>Generated at (UTC)</td>
    <td style="font-family: var(--font-mono)">{{ generated_at }}</td>
  </tr>
  <tr>
    <td>Report fingerprint (SHA-256)</td>
    <td style="font-family: var(--font-mono); font-size:8pt; word-break:break-all;">{{ report_fingerprint }}</td>
  </tr>
</table>

<div class="box" style="font-size:8.5pt;">
  The fingerprint is SHA-256(canonical JSON of DesignResult). Reproduce this report by
  supplying the identical input spec and kernel version — the fingerprint will match.
</div>

<h3>Complete Input Specification</h3>
<table>
  <tr><th colspan="2" style="background:var(--color-brand-light);">Geometry</th></tr>
  <tr><td style="width:45%">Span</td>                <td class="num">{{ geom.span_m }} m</td></tr>
  <tr><td>Eaves height</td>            <td class="num">{{ geom.eaves_height_m }} m</td></tr>
  <tr><td>Roof pitch</td>              <td class="num">{{ geom.roof_pitch_deg }}&deg;</td></tr>
  <tr><td>Bay spacing</td>             <td class="num">{{ geom.bay_spacing_m }} m</td></tr>
  <tr><td>Number of bays</td>          <td class="num">{{ geom.number_of_bays }}</td></tr>
  <tr><td>Apex height (computed)</td>  <td class="num">{{ "%.3f"|format(geom.apex_height_m) }} m</td></tr>

  <tr><th colspan="2" style="background:var(--color-brand-light);">Dead Loads (characteristic)</th></tr>
  <tr><td>Roof area load</td>          <td class="num">{{ dead.roof_kpa }} kPa</td></tr>
  <tr><td>Services load</td>           <td class="num">{{ dead.services_kpa }} kPa</td></tr>
  <tr><td>Wall cladding load</td>      <td class="num">{{ dead.wall_cladding_kpa }} kPa</td></tr>

  <tr><th colspan="2" style="background:var(--color-brand-light);">Wind</th></tr>
  <tr><td>Basic wind speed</td>        <td class="num">{{ wind.basic_wind_speed_ms }} m/s</td></tr>
  <tr><td>Terrain category</td>        <td>{{ wind.terrain_category.value }}</td></tr>
  <tr><td>Site altitude</td>           <td class="num">{{ wind.site_altitude_m }} m</td></tr>
  <tr><td>Dominant opening</td>        <td>{{ "Yes" if wind.has_dominant_opening else "No" }}</td></tr>

  <tr><th colspan="2" style="background:var(--color-brand-light);">Materials and Fixity</th></tr>
  <tr><td>Steel grade</td>             <td>{{ steel_grade }}</td></tr>
  <tr><td>Base fixity</td>             <td>{{ base_fixity }}</td></tr>

  <tr><th colspan="2" style="background:var(--color-brand-light);">Restraints (LTB unbraced lengths)</th></tr>
  <tr><td>Rafter restraint spacing</td>
      <td class="num">{% if restraints_rafter_m %}{{ restraints_rafter_m }} m{% else %}Unrestrained (full rafter half-length){% endif %}</td></tr>
  <tr><td>Column restraint spacing</td>
      <td class="num">{% if restraints_column_m %}{{ restraints_column_m }} m{% else %}Unrestrained (full eaves height){% endif %}</td></tr>
</table>

