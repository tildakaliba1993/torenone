<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TorenOne — Structural Calculation Report</title>
  <style>
    /* ------------------------------------------------------------------ */
    /* Design tokens — steel-blue brand                                    */
    /* ------------------------------------------------------------------ */
    :root {
      --color-brand:       #1B3A57;
      --color-brand-light: #2D5F8A;
      --color-pass:        #166534;
      --color-pass-bg:     #DCFCE7;
      --color-fail:        #991B1B;
      --color-fail-bg:     #FEE2E2;
      --color-warn:        #92400E;
      --color-warn-bg:     #FEF3C7;
      --color-border:      #D1D5DB;
      --color-text:        #111827;
      --color-muted:       #6B7280;
      --font-mono:         "Courier New", Courier, monospace;
      --font-sans:         Arial, Helvetica, sans-serif;
    }

    /* ------------------------------------------------------------------ */
    /* Base                                                                */
    /* ------------------------------------------------------------------ */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-sans);
      font-size: 10pt;
      color: var(--color-text);
      background: #fff;
      padding: 20mm 18mm;
    }

    /* ------------------------------------------------------------------ */
    /* Cover / header                                                      */
    /* ------------------------------------------------------------------ */
    .cover {
      background: var(--color-brand);
      color: #fff;
      padding: 18pt 20pt;
      margin-bottom: 16pt;
      border-radius: 3pt;
    }
    .cover h1 { font-size: 18pt; font-weight: bold; margin-bottom: 4pt; }
    .cover .subtitle { font-size: 10pt; opacity: 0.85; }
    .cover .meta { font-size: 9pt; margin-top: 8pt; opacity: 0.75; font-family: var(--font-mono); }
    .cover-logo { margin-bottom: 11pt; }
    .cover-logo svg { height: 19pt; width: auto; display: block; }
    .cover-rule { height: 1pt; background: rgba(255,255,255,0.18); margin: 11pt 0; }
    .doc-control { width: 100%; border-collapse: collapse; margin-bottom: 16pt; font-size: 9pt; }
    .doc-control td { border: 0.5pt solid var(--color-border); padding: 4pt 7pt; vertical-align: top; }
    .doc-control td.k { background: #F3F4F6; font-weight: bold; width: 16%; white-space: nowrap; }
    .doc-control td.v { width: 34%; }

    /* ------------------------------------------------------------------ */
    /* Engineer sign-off block                                             */
    /* ------------------------------------------------------------------ */
    .signoff {
      margin-top: 18pt;
      border: 1pt solid var(--color-border);
      border-radius: 3pt;
      padding: 11pt 13pt 13pt;
      page-break-inside: avoid;
    }
    .signoff h3 { margin: 0; color: var(--color-brand); }
    .signoff .note { font-size: 8.5pt; color: var(--color-muted); margin: 4pt 0 4pt; }
    .signoff-table { width: 100%; border-collapse: separate; border-spacing: 14pt 9pt; }
    .signoff-table td { width: 50%; vertical-align: bottom; }
    .signoff-table .label { font-size: 8pt; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.04em; }
    .signoff-table .line { border-bottom: 1pt solid var(--color-text); height: 22pt; }

    /* ------------------------------------------------------------------ */
    /* Section headings                                                    */
    /* ------------------------------------------------------------------ */
    h2 {
      font-size: 12pt;
      font-weight: bold;
      color: var(--color-brand);
      border-bottom: 1.5pt solid var(--color-brand);
      padding-bottom: 3pt;
      margin: 16pt 0 8pt;
    }
    h3 {
      font-size: 10pt;
      font-weight: bold;
      color: var(--color-brand-light);
      margin: 10pt 0 4pt;
    }

    /* ------------------------------------------------------------------ */
    /* Tables                                                              */
    /* ------------------------------------------------------------------ */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10pt;
      font-size: 9.5pt;
    }
    th {
      background: var(--color-brand);
      color: #fff;
      text-align: left;
      padding: 4pt 6pt;
      font-weight: bold;
    }
    td {
      padding: 3pt 6pt;
      border-bottom: 0.5pt solid var(--color-border);
    }
    tr:nth-child(even) td { background: #F9FAFB; }

    /* Monospaced numeric columns */
    .num { font-family: var(--font-mono); text-align: right; }

    /* ------------------------------------------------------------------ */
    /* Pass / fail badges  (PRD FR-19: icon + label + colour, never alone) */
    /* ------------------------------------------------------------------ */
    .badge {
      display: inline-block;
      padding: 1pt 5pt;
      border-radius: 2pt;
      font-weight: bold;
      font-size: 8.5pt;
      font-family: var(--font-mono);
    }
    .badge-pass { background: var(--color-pass-bg); color: var(--color-pass); }
    .badge-near { background: var(--color-warn-bg); color: var(--color-warn); }
    .badge-fail { background: var(--color-fail-bg); color: var(--color-fail); }

    /* ------------------------------------------------------------------ */
    /* Utilisation bar                                                     */
    /* ------------------------------------------------------------------ */
    .util-bar-wrap { width: 60pt; height: 7pt; background: #E5E7EB; display: inline-block;
                     border-radius: 1pt; vertical-align: middle; }
    .util-bar      { height: 100%; border-radius: 1pt; }
    .util-low      { background: var(--color-pass); }
    .util-mid      { background: #D97706; }
    .util-high     { background: var(--color-fail); }

    /* ------------------------------------------------------------------ */
    /* Info / warning boxes                                                */
    /* ------------------------------------------------------------------ */
    .box {
      border-left: 3pt solid var(--color-brand);
      background: #F0F4F8;
      padding: 7pt 10pt;
      margin: 8pt 0;
      font-size: 9pt;
    }
    .box-warn {
      border-left-color: #D97706;
      background: var(--color-warn-bg);
      color: var(--color-warn);
    }
    .box-prov {
      border-left-color: #D97706;
      background: var(--color-warn-bg);
    }
    .box-stamped {
      border-left-color: var(--color-pass);
      background: var(--color-pass-bg);
      color: var(--color-pass);
    }
    .stamp-mark {
      border: 1.5pt solid var(--color-pass);
      border-radius: 3pt;
      padding: 8pt 11pt;
      color: var(--color-pass);
      background: var(--color-pass-bg);
      font-size: 9pt;
    }
    .stamp-mark .stamp-title { font-weight: bold; letter-spacing: 0.04em; text-transform: uppercase; }
    .stamp-mark .stamp-name { font-size: 11pt; font-weight: bold; margin-top: 3pt; }
    .stamp-mark .stamp-meta { color: var(--color-text); margin-top: 3pt; }

    /* ------------------------------------------------------------------ */
    /* Provenance label                                                    */
    /* ------------------------------------------------------------------ */
    .provenance {
      font-size: 8pt;
      color: var(--color-muted);
      font-style: italic;
      margin-top: 12pt;
      border-top: 0.5pt solid var(--color-border);
      padding-top: 6pt;
    }

    /* ------------------------------------------------------------------ */
    /* Page break hints (WeasyPrint honours these)                        */
    /* ------------------------------------------------------------------ */
    .page-break { page-break-before: always; }
  </style>
</head>
<body>

{# ================================================================== #}
{# Macro: status_badge(utilisation, passed)                           #}
{# Three-tier status per PRD FR-19: icon + label + colour, never      #}
{# colour alone.                                                       #}
{#   PASS       util < near_limit_threshold (green  ✓)                #}
{#   NEAR LIMIT threshold ≤ util ≤ 1.0      (amber  ⚠)               #}
{#   FAIL       util > 1.0 OR not passed    (red    ✗)                #}
{# ================================================================== #}
{% macro status_badge(utilisation, passed, informational=false) -%}
  {%- if informational -%}
    <span class="badge badge-near">&#9888; ADVISORY</span>
  {%- elif not passed or utilisation > 1.0 -%}
    <span class="badge badge-fail">&#10007; FAIL</span>
  {%- elif utilisation >= near_limit_threshold -%}
    <span class="badge badge-near">&#9888; NEAR LIMIT</span>
  {%- else -%}
    <span class="badge badge-pass">&#10003; PASS</span>
  {%- endif -%}
{%- endmacro %}

{# Macro: checks_table(checks, show_detail) — a clause-referenced utilisation + status table.
   show_detail=false hides the per-row detail text (used for the advisory wind sub-table,
   whose shared caveat is stated once above the table instead of on every row). #}
{% macro checks_table(checks, show_detail=true) -%}
<table>
  <tr>
    <th style="width:36%">Check</th>
    <th style="width:30%">Clause</th>
    <th style="width:14%" class="num">Utilisation</th>
    <th style="width:20%">Status</th>
  </tr>
  {% for c in checks %}
  <tr>
    <td>{{ c.name }}</td>
    <td style="font-family: var(--font-mono); font-size:8pt;">{{ c.clause }}</td>
    <td class="num">{{ "%.4f"|format(c.utilisation) }}</td>
    <td>
      {{ status_badge(c.utilisation, c.passed, c.informational) }}
      {% if show_detail and c.detail %}<br><span style="font-size:7.5pt; color:var(--color-muted);">{{ c.detail }}</span>{% endif %}
    </td>
  </tr>
  {% endfor %}
</table>
{%- endmacro %}

